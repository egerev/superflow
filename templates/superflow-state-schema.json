{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Superflow State",
  "type": "object",
  "required": [
    "version",
    "phase",
    "stage",
    "stage_index",
    "last_updated"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "phase": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "phase_label": {
      "type": "string"
    },
    "sprint": {
      "type": [
        "integer",
        "null"
      ]
    },
    "stage": {
      "type": "string"
    },
    "stage_index": {
      "type": "integer"
    },
    "tasks_done": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "tasks_total": {
      "type": "integer"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "context": {
      "type": "object",
      "properties": {
        "user_context": {
          "type": "object"
        },
        "detected_stack": {
          "type": "string"
        },
        "secondary_provider": {
          "type": [
            "string",
            "null"
          ]
        },
        "plan_file": {
          "type": [
            "string",
            "null"
          ]
        },
        "spec_file": {
          "type": [
            "string",
            "null"
          ]
        },
        "preflight": {
          "type": "object",
          "properties": {
            "stack": {
              "type": "string"
            },
            "team_size": {
              "type": "string"
            },
            "ci": {
              "type": "string"
            },
            "python3": {
              "type": "string"
            },
            "pm": {
              "type": "string"
            },
            "formatters": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "tech_debt": {
          "type": "object",
          "properties": {
            "total_todos": {
              "type": "integer"
            },
            "files_over_500_loc": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "untested_modules": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "security_issues": {
              "type": "integer"
            },
            "generated_at": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "approval": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "all",
                "custom",
                "skip"
              ]
            },
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "brief_file": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to the product brief file"
        },
        "charter_file": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to the project charter file"
        },
        "completion_data_file": {
          "type": [
            "string",
            "null"
          ],
          "description": "Path to completion data JSON"
        },
        "governance_mode": {
          "type": "string",
          "enum": [
            "light",
            "standard",
            "critical"
          ],
          "default": "standard",
          "description": "Review governance level"
        },
        "runtime": {
          "type": "string",
          "enum": [
            "claude",
            "codex"
          ],
          "default": "claude",
          "description": "Detected runtime environment \u2014 persisted for compaction recovery"
        },
        "run_id": {
          "type": "string",
          "description": "UUID generated at session start, persisted across compaction/resume. Corresponds to run_id field in event-schema.json envelope."
        }
      }
    },
    "heartbeat": {
      "type": "object",
      "description": "Compaction-recovery snapshot written by the orchestrator at sprint start and each stage transition. Optional — v4.8 states without this field remain valid.",
      "additionalProperties": false,
      "properties": {
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of the last heartbeat write"
        },
        "current_sprint": {
          "type": ["integer", "null"],
          "description": "Sprint number currently in progress. Null when state was written before sprint assignment."
        },
        "sprint_goal": {
          "type": "string",
          "description": "Short one-line description of the current sprint goal"
        },
        "merge_method": {
          "type": "string",
          "description": "Merge method for Phase 3. Canonical: 'rebase' → actual command 'gh pr merge <N> --rebase --delete-branch'. Never local git merge."
        },
        "active_worktree": {
          "type": "string",
          "description": "Filesystem path of the active git worktree"
        },
        "active_branch": {
          "type": "string",
          "description": "Name of the active feature branch"
        },
        "must_reread": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "File paths the orchestrator MUST have in context this turn before advancing work"
        },
        "last_review_verdict": {
          "type": ["string", "null"],
          "description": "Most recent unified review verdict, e.g. 'APPROVE'. Null if no review has run yet."
        },
        "phase2_step": {
          "type": "string",
          "description": "Stage name enum: setup | implementation | review | par | docs | ship. (Supersedes early-draft integer form.)"
        }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "phase",
          "completed_at"
        ],
        "properties": {
          "phase": {
            "type": "integer"
          },
          "sprint": {
            "type": "integer"
          },
          "completed_at": {
            "type": "string"
          },
          "pr": {
            "type": "string"
          }
        }
      }
    }
  }
}
